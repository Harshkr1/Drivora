<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update <%=folder.name%></title>
  </head>

  <body>
    <div>
      <a href="/log-out">Logout</a>
      <h1>Update <%=folder.name%></h1>
      <form action="/folder/update-folder/<%= folder.id%>" method="POST">
        <input
          type="text"
          name="folderName"
          placeholder="folderName"
          value="<%= folder.folder_name %>"
          required
        />
        <div>
          <button type="submit">Update</button>
        </div>
      </form>
    </div>
  </body>
</html>
