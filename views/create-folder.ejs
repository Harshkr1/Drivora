<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Drivora</title>
  </head>

  <body>
    <div>
      <a href="/log-out">Logout</a>
      <h1>Add a folder:</h1>
      <form action="/folder/create-folder" method="POST">
        <input
          type="text"
          name="folderName"
          placeholder="folderName"
          required
        />
        <div>
          <button type="submit">Add</button>
        </div>
      </form>
    </div>
  </body>
</html>
